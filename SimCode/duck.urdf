<?xml version="1.0"?>
<robot name="duck">

  <!-- BODY -->
  <link name="body">
    <visual>
      <geometry>
        <box size="0.4 0.3 0.2"/>
      </geometry>
      <material name="yellow">
        <color rgba="1 1 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.4 0.3 0.2"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01"/>
    </inertial>
  </link>

  <!-- LEFT SHIN -->
  <link name="left_shin">
    <visual>
      <origin xyz="0 0 -0.075"/>
      <geometry>
        <box size="0.05 0.05 0.15"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.075"/>
      <geometry>
        <box size="0.05 0.05 0.15"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.075"/>
      <mass value="0.2"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001"/>
    </inertial>
  </link>

  <!-- RIGHT SHIN -->
  <link name="right_shin">
    <visual>
      <origin xyz="0 0 -0.075"/>
      <geometry>
        <box size="0.05 0.05 0.15"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.075"/>
      <geometry>
        <box size="0.05 0.05 0.15"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.075"/>
      <mass value="0.2"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001"/>
    </inertial>
  </link>

  <!-- HEAD -->
  <link name="head">
    <visual>
      <origin xyz="0.12 0 0.05"/>
      <geometry>
        <box size="0.15 0.15 0.18"/>
      </geometry>
      <material name="yellow">
        <color rgba="1 1 0 1"/>
      </material>
    </visual>
    <inertial>
      <origin xyz="0.12 0 0.05"/>
      <mass value="0.3"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001"/>
    </inertial>
  </link>

  <!-- EYES AND BEAK - zero mass since fixed to head -->
  <link name="left_eye">
    <visual>
      <origin xyz="0.20 0.05 0.10"/>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" iyy="0.0" izz="0.0"/>
    </inertial>
  </link>

  <link name="right_eye">
    <visual>
      <origin xyz="0.20 -0.05 0.10"/>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" iyy="0.0" izz="0.0"/>
    </inertial>
  </link>

  <link name="beak">
    <visual>
      <origin xyz="0.12 0 0.08"/>
      <geometry>
        <box size="0.06 0.03 0.02"/>
      </geometry>
      <material name="orange">
        <color rgba="1 0.5 0 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" iyy="0.0" izz="0.0"/>
    </inertial>
  </link>

  <!-- FEET -->
  <link name="left_foot">
    <visual>
      <origin xyz="0 0 -0.01"/>
      <geometry>
        <box size="0.15 0.10 0.02"/>
      </geometry>
      <material name="orange">
        <color rgba="1 0.5 0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.01"/>
      <geometry>
        <box size="0.15 0.10 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.01"/>
      <mass value="0.1"/>
      <inertia ixx="0.0005" iyy="0.0005" izz="0.0005"/>
    </inertial>
  </link>

  <link name="right_foot">
    <visual>
      <origin xyz="0 0 -0.01"/>
      <geometry>
        <box size="0.15 0.10 0.02"/>
      </geometry>
      <material name="orange">
        <color rgba="1 0.5 0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.01"/>
      <geometry>
        <box size="0.15 0.10 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.01"/>
      <mass value="0.1"/>
      <inertia ixx="0.0005" iyy="0.0005" izz="0.0005"/>
    </inertial>
  </link>

  <!-- JOINTS -->
  <joint name="left_hip" type="revolute">
    <parent link="body"/>
    <child link="left_shin"/>
    <origin xyz="0 0.12 -0.1"/>
    <axis xyz="0 1 0"/>
    <limit effort="50" velocity="2" lower="-1.0" upper="1.0"/>
  </joint>

  <joint name="right_hip" type="revolute">
    <parent link="body"/>
    <child link="right_shin"/>
    <origin xyz="0 -0.12 -0.1"/>
    <axis xyz="0 1 0"/>
    <limit effort="50" velocity="2" lower="-1.0" upper="1.0"/>
  </joint>

  <joint name="neck" type="fixed">
    <parent link="body"/>
    <child link="head"/>
    <origin xyz="0 0 0.1"/>
  </joint>

  <joint name="left_eye_joint" type="fixed">
    <parent link="head"/>
    <child link="left_eye"/>
    <origin xyz="0 0 0"/>
  </joint>

  <joint name="right_eye_joint" type="fixed">
    <parent link="head"/>
    <child link="right_eye"/>
    <origin xyz="0 0 0"/>
  </joint>

  <joint name="beak_joint" type="fixed">
    <parent link="head"/>
    <child link="beak"/>
    <origin xyz="0.06 0 0"/>
  </joint>

  <joint name="left_ankle" type="fixed">
    <parent link="left_shin"/>
    <child link="left_foot"/>
    <origin xyz="0.03 0 -0.15"/>
  </joint>

  <joint name="right_ankle" type="fixed">
    <parent link="right_shin"/>
    <child link="right_foot"/>
    <origin xyz="0.03 0 -0.15"/>
  </joint>

</robot>